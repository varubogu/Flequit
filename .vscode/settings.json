{
    "cSpell.words": [
        "flequit",
        "qwik",
        "tauri",
        "varubogu"
    ],
    "svelte.enable-ts-plugin": true,
    "i18n-ally.localesPaths": [
        "src/i18n"
    ],
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "always",
    },
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "svelte"
    ],
}